  </object>
  <object Name="Vantabloom" Load="Merge">
    <part Name="Render" DisplayName="▶vantabloom" />
    <part Name="Description" Short="▶Petali scuri si inclinano verso un punto interiore di armonia e formano un bellissimo calice floreale. La luce gocciola dal confine della sua influenza e si infiltra nel vuoto." />
