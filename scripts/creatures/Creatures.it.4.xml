  <object Name="Saltwurm" Load="Merge">
    <part Name="Render" DisplayName="▶kraken del sale" />
    <part Name="Description" Short="▶Una valanga di sale da una duna impostora rivela qualcosa del dolorante sogno del tardo mondo: una vivente grotta di iodio, nutrita fino alla =pronouns.possessive= taglia implausibile dalla vasta e galleggiante pianura ondosa di Moghra'yi. Una tenda di pioggia di vetro scorre sull'afflusso del =pronouns.possessive= filtro alimentare, e dietro, il pianeta ingerito giace in tratti polverizzati." />
  </object>
